package day10;

import java.util.Arrays;

public class PrimeNumbers {

	int op[][] = new int[10][30];
	public void isPrime() {
		for(int row=0; row<10;row++) {
			int low = row*100;
			int high = 100*(row+1);
			int m =0;		
			
			for(int i = low; i <= high; i++) {
				if(i==0 || i==1) {
					continue;
				}
				int k=i;
				if(k==2) {
					op[row][m++]= k;
					continue;
				}
				boolean isPrime =true ;
				if(k%2==0) {
					continue;
				}
				for(int j=3; j <=k/2; j=j+2)
				{
					if(k%j == 0)
					{
						isPrime = false;
						break;
					}
				}
				if(isPrime == true) {
					op[row][m++]=i;
				}
			}
		}
		for(int i = 0;i<10;i++) {
			for(int j=0;j<30;j++) {
				if(op[i][j]!=0) {
				System.out.print(op[i][j]+ " ");
				}
			}
			System.out.println();
		}
			
	}
	
