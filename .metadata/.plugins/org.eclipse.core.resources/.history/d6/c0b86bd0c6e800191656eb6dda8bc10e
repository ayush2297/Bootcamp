package day11;

import java.util.Arrays;
import java.util.Scanner;

public class InfiniteSeries {

	Scanner sc = new Scanner(System.in);
	public void generateSeries() {
	
		int seriesOf = 1, row =1;
		int [][]arr = new int [10][10];
		System.out.println("enter harmonic range 'n': ");
		int n = sc.nextInt();
		while (row<=10) {
			int sum = row;
			for(int i=1;i<n;i++) {
				sum = sum + (1/i);
				arr[row][i] = sum;
			}
			row++;
		}
		for(int[] element : arr) {
			System.out.println(Arrays.toString(element));
		}
	}
	
	public static void main(String [] args) {
		InfiniteSeries inf = new InfiniteSeries();
		inf.generateSeries();
	}
	
}
