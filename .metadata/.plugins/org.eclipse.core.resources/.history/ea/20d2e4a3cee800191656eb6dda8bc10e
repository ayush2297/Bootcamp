package day11;

import java.util.Arrays;
import java.util.Scanner;

public class InfiniteSeries {

	Scanner sc = new Scanner(System.in);
	public void generateSeries() {
	
		int seriesOf = 1, row =0;
		System.out.println("enter harmonic range 'n': ");
		int n = sc.nextInt();
		double [][]arr = new double [5][n];
		double sum = 0;
		double divider = 1;
		int check =1;
		arr[0][0] = 0;
		while(row<10) {
			for(double i=1;i<=n ;i++) {
				sum = sum + (1/(divider));
				if(check!=(int)sum) {
					arr[++row][0]= sum;
					check++;
					break;
				}
				else {
					arr[row][(int)i] = sum;
					divider++;
				}
			}
		}
		
		for(int i = 0; i<n;i++) {
			for(int j=0;j<n;j++) {
				System.out.print(arr[i][j]+"\t");	
			}
			System.out.println();
		}
	}
	
	public static void main(String [] args) {
		InfiniteSeries inf = new InfiniteSeries();
		inf.generateSeries();
	}
	
}
