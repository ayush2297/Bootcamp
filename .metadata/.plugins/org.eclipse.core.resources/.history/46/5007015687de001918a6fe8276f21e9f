package com.bridgelabz.lib;
import java.util.*;


public class BLStats {

	/**
     * Returns the maximum value in the specified array.
     *
     * @param  a the array
     * @return the maximum value in the array {@code a[]};
     *         {@code Double.NEGATIVE_INFINITY} if no such value
     */

	public static void validateNotNull(double [] a) {
		if(a==null) {
			throw new IllegalArgumentException("\nno array input/ array does not exist\n");
		}
	}
	
	public static double max(double[] a) {
        validateNotNull(a);

        double max = Double.NEGATIVE_INFINITY;
        for (int i = 0; i < a.length; i++) {
            if (Double.isNaN(a[i])) return Double.NaN;
            if (a[i] > max) max = a[i];
        }
        return max;
    }

	
}
